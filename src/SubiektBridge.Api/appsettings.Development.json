{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080"
      },
      "Https": {
        "Url": "https://0.0.0.0:8443"
      }
    }
  },
  "Bridge": {
    "Token": "dev-token",
    "UseFakeSfera": true,
    "AllowedRawSferaMethods": [
      "GetVersion",
      "Magazyny.Liczba",
      "Platnosci.Liczba"
    ]
  }
}
