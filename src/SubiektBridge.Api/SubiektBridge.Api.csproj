<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>SubiektBridge.Api</RootNamespace>
    <AssemblyName>SubiektBridge.Api</AssemblyName>
    <UserSecretsId>subiekt-bridge-dev</UserSecretsId>
    <!-- CA1416 = "Validate platform compatibility" - tłumimy bo COM celowo windows-only,
         a [SupportedOSPlatform] mamy tam gdzie trzeba. -->
    <NoWarn>$(NoWarn);CA1416</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" Version="9.0.0" />
    <PackageReference Include="Microsoft.Data.SqlClient" Version="6.0.1" />
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="9.0.0" />
    <PackageReference Include="Serilog.AspNetCore" Version="9.0.0" />
    <PackageReference Include="Serilog.Sinks.File" Version="6.0.0" />
    <!-- DLR (dynamic) jest wbudowany w .NET 10 - nie trzeba osobnej referencji Microsoft.CSharp. -->

  </ItemGroup>

</Project>
